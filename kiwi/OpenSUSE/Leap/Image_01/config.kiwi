    <packages type="image" profiles="azure-base">
        <archive name="azure.tar.gz"/>
        <package name="dracut-kiwi-oem-repart"/>
        <package name="cloud-netconfig-azure"/>
        <package name="hyper-v"/>
        <package name="microsoft-dracut-config"/>
