    <!-- There are no updates repos for Leap 16 -->
    <!-- <repository type="rpm-md">
        <source path="https://download.opensuse.org/update/leap/16.0/oss/"/>
    </repository>

    <repository type="rpm-md">
        <source path="https://download.opensuse.org/update/leap/16.0/non-oss/"/>
    </repository> -->

    <preferences profiles="Azure" arch="x86_64">
        <type
          vhdfixedtag="f3aed66d-57ef-4268-bce4-8ca20550f851"
          bootpartition="false"
          devicepersistency="by-uuid"
          filesystem="btrfs"
          firmware="uefi"
          image="oem"
          kernelcmdline="console=ttyS0 net.ifnames=0 iommu.passthrough=1 dis_ucode_ldr earlyprintk=ttyS0 multipath=off nvme_core.io_timeout=240 rootdelay=300 scsi_mod.use_blk_mq=1 USE_BY_UUID_DEVICE_NAMES=1 security=selinux selinux=1"
          btrfs_quota_groups="true"
          btrfs_root_is_snapshot="true"
          efipartsize="512"
          format="vhd-fixed"
          formatoptions="force_size">

            <bootloader name="grub2" timeout="1" console="serial" timeout_style="countdown"/>
            <size unit="M">30720</size>
            <systemdisk>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/i386-pc"/>
                <volume name="boot/writable"/>
                <volume name="usr/local"/>
                <volume name="var"/>
                <volume name="boot/grub2/x86_64-efi" mountpoint="boot/grub2/x86_64-efi"/>
            </systemdisk>
        </type>
    </preferences>
    <preferences profiles="Azure" arch="aarch64">
        <type
          vhdfixedtag="f3aed66d-57ef-4268-bce4-8ca20550f851"
          bootpartition="false"
          devicepersistency="by-uuid"
          filesystem="btrfs"
          firmware="uefi"
          image="oem"
          kernelcmdline="console=tty1 console=ttyAMA0 net.ifnames=0 iommu.passthrough=1 multipath=off nvme_core.io_timeout=240 rootdelay=300 scsi_mod.use_blk_mq=1 USE_BY_UUID_DEVICE_NAMES=1 earlycon=pl011,0xeffec000 initcall_blacklist=arm_pmu_acpi_init security=selinux selinux=1"
          btrfs_quota_groups="true"
          btrfs_root_is_snapshot="true"
          efipartsize="512"
          format="vhd-fixed"
          formatoptions="force_size">

            <bootloader name="grub2" timeout="1" console="serial" timeout_style="countdown"/>
            <size unit="M">30720</size>
            <systemdisk>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/i386-pc"/>
                <volume name="boot/writable"/>
                <volume name="usr/local"/>
                <volume name="var"/>
                <volume name="boot/grub2/arm64-efi" mountpoint="boot/grub2/arm64-efi"/>
            </systemdisk>
        </type>
    </preferences>

    <preferences profiles="KVM" arch="x86_64">
        <type
          image="oem"
          format="qcow2"
          filesystem="btrfs"
          firmware="uefi"
          efipartsize="512"
          kernelcmdline="console=ttyS0 console=tty0 security=selinux selinux=1 net.ifnames=0"
          bootpartition="false"
          bootkernel="default"
          devicepersistency="by-uuid">

            <bootloader name="grub2" timeout="1" console="serial" timeout_style="countdown"/>
            <size unit="G">10</size>
            <oemconfig>
                <oem-resize>true</oem-resize>
            </oemconfig>

            <systemdisk>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/i386-pc"/>
                <volume name="boot/writable"/>
                <volume name="usr/local"/>
                <volume name="var"/>
                <volume name="boot/grub2/x86_64-efi" mountpoint="boot/grub2/x86_64-efi"/>
            </systemdisk>
        </type>
    </preferences>
    <preferences profiles="KVM" arch="aarch64">
        <type
          image="oem"
          format="qcow2"
          filesystem="btrfs"
          firmware="uefi"
          efipartsize="512"
          kernelcmdline="console=tty1 console=ttyAMA0 security=selinux selinux=1 net.ifnames=0"
          bootpartition="false"
          bootkernel="default"
          devicepersistency="by-uuid">

            <bootloader name="grub2" timeout="1" console="serial" timeout_style="countdown"/>
            <size unit="G">10</size>
            <oemconfig>
                <oem-resize>true</oem-resize>
            </oemconfig>

            <systemdisk>
                <volume name="home"/>
                <volume name="root"/>
                <volume name="opt"/>
                <volume name="srv"/>
                <volume name="boot/grub2/i386-pc"/>
                <volume name="boot/writable"/>
                <volume name="usr/local"/>
                <volume name="var"/>
                <volume name="boot/grub2/arm64-efi" mountpoint="boot/grub2/arm64-efi"/>
            </systemdisk>
        </type>
    </preferences>


    <packages type="image">
        <package name="aaa_base"/>
        <package name="bash"/>
        <package name="btrfsprogs"/>
        <package name="btrfsmaintenance"/>
        <package name="build-key"/>
