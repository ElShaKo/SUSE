        <package name="openldap2-client"/>
        <package name="polkit-default-privs"/>
        <package name="psmisc"/>
        <!-- <package name="quota"/> -->
        <package name="rsync"/>
        <!-- <package name="screen"/> -->
        <package name="strace"/>
