<?xml version="1.0" encoding="utf-8"?>

<image schemaversion="7.5" name="openSUSE-Leap-16.0" displayname="openSUSE-Leap-16.0">
    <description type="system">
        <author></author>
        <contact></contact>
        <specification>openSUSE Leap 16.0 generic image</specification>
    </description>

    <profiles>
        <profile name="azure-base" description="Base profile for Microsoft Azure"/>
        <profile name="Azure" description="Configuration for Microsoft Azure">
            <requires profile="azure-base"/>
        </profile>

        <profile name="kvm-base" description="Base profile for KVM"/>
        <profile name="KVM" description="Configuration for KVM">
            <requires profile="kvm-base"/>
        </profile>
    </profiles>

    <preferences>
        <version>0.1.0</version>
        <locale>en_US</locale>
        <keytable>us</keytable>
        <timezone>UTC</timezone>
        <packagemanager>zypper</packagemanager>        
    </preferences>

    <users>
        <user name="root" groups="root" home="/root" password="$6$4DEILW0qmKzLl1JH$2btJEAvftGsGpanJ8BueIPLgR.y1Sq7DyQgGOhzqNESD09t18Kwwb5OouuV0gwgQ6GsvuyqduZcYTcM3B6Kb/."/>
        <user name="devops" groups="users" home="/home/devops" password="$6$ytpiAF0w9HtmFKUU$D7TJLFbUYtU7xEL03PCgho6Q0EX00jIpz2P2.iq/DbqUHnIttvc7uAVu/iX7jjYZf571DxZMyj5YEI1HmJB0H/"/>
    </users>

    <!-- Only for build server -->
    <!-- <repository type="rpm-md">
        <source path="obsrepositories:/"/>
    </repository> -->

    <!-- Only for manual build -->
