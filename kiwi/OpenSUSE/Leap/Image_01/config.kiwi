        <package name="shadow"/>
        <package name="systemd"/>
        <package name="terminfo-base"/>
        <package name="timezone"/>
        <package name="user(nobody)"/>
        <package name="util-linux"/>
        <package name="wtmpdb"/>
        <package name="xfsprogs"/>
        <package name="grub2"/>
        <package name="grub2-arm64-efi" arch="aarch64"/>
        <package name="grub2-x86_64-efi" arch="x86_64"/>
        <package name="mokutil"/>
        <package name="release-notes-openSUSE"/>
        <package name="shim"/>
        <package name="sudo"/>
        <package name="systemd-default-settings-branding-openSUSE"/>
        <package name="NetworkManager"/>
        <package name="NetworkManager-branding-openSUSE"/>
        <package name="vim"/>

        <!-- openSCAP -->
        <package name="openscap-utils"/>
        <package name="openscap-content"/>
        <package name="openscap"/>
        <package name="libopenscap33"/>
        <package name="scap-security-guide"/>
    </packages>

    <packages type="image" profiles="azure-base,kvm-base">
        <archive name="pubcloud.tar.gz"/>
        <package name="aaa_base-extras"/>
        <package name="at-spi2-core"/>
        <package name="attr"/>
        <package name="bc"/>
        <package name="binutils"/>
        <!-- <package name="cifs-utils"/> -->
        <package name="crash"/>
